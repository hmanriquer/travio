# ============================================================
#  Travio — Environment Variables
#  Copy this file to .env.local and fill in the values.
#  Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Database (Vercel Postgres)
# Get these from your Vercel dashboard → Storage → your DB
# ------------------------------------------------------------
POSTGRES_URL="postgres://..."
POSTGRES_PRISMA_URL="postgres://...?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NO_SSL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."
POSTGRES_USER="..."
POSTGRES_HOST="..."
POSTGRES_PASSWORD="..."
POSTGRES_DATABASE="..."

# ------------------------------------------------------------
# Auth.js (NextAuth v5)
# Generate a secret with: npx auth secret
# or: openssl rand -base64 32
# ------------------------------------------------------------
AUTH_SECRET="replace-with-a-random-32+-character-secret"

# Optional — set explicitly in production to avoid redirect issues.
# In development Next.js infers this automatically.
# AUTH_URL="https://your-domain.com"
